{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "probe-rs-debug",
            "request": "launch",

            "name": "STM32F410 Debug",

            "cwd": "${workspaceFolder}",

            "chip": "STM32F410RBTx",

            "runtimeExecutable": "probe-rs",
            "runtimeArgs": ["dap-server"],

            "flashingConfig": {
                "flashingEnabled": true,

                "haltAfterReset": true,

                "formatOptions": {
                    "binaryFormat": "elf"
                }
            },

            "coreConfigs": [
                {
                    "coreIndex": 0,

                    "programBinary": "${workspaceFolder}/target/thumbv7em-none-eabihf/debug/stm32f4-blink",

                    "svdFile": "${workspaceFolder}/stm32f410.svd",

                    "rttEnabled": true,

                    "rttChannelFormats": [
                        {
                            "channelNumber": 0,
                            "dataFormat": "String",
                            "showTimestamps": true
                        }
                    ]
                }
            ],

            "env": {
                "RUST_LOG": "info"
            },

            "consoleLogLevel": "Info"
        }
    ]
}